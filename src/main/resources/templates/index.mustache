<!DOCTYPE>
<html>
<head>
    <link type="text/css" href="{{{canvasCommonCss}}}" rel="stylesheet"/>
    <link type="text/css" href="{{{canvasBrandCss}}}" rel="stylesheet"/>
    <link type="text/css" href="/resources/style.css?{{commitId}}" rel="stylesheet"/>
    <script src="/webjars/jquery/3.1.1/jquery.min.js"></script>
    <script src="/resources/import.js?{{commitId}}"></script>
    <title>{{applicationName}}</title>
</head>
<body>

<div class="content-box">
    {{#alert}}
        <p>
        <div class="ic-flash-{{type.css}}">
            <div class="ic-flash__icon" aria-hidden="true">
                <i class="icon-{{type.icon}}"></i>
            </div>
            {{message}}
        </div>
        </p>
    {{/alert}}
    <div class="header-bar">
        <h3 class="ic-Action-header__Heading">Import File</h3>
        <p>
            This tool allows you to import a set of events contained in a CSV file into the
            <a href="{{{courseCalendarUrl}}}" target="_top">course calendar</a>.
            The file has to be specifically formatted for the importer. An
            <a href="/resources/example.csv">example file</a> file can be downloaded, edited
            locally and then uploaded again to import (You may delete extraneous columns in
            the example file, if necessary).
        </p>
        <form class="ic-Form-group ic-Form-group--horizontal" method="post" action="upload"
              enctype="multipart/form-data">
            <div class="ic-Form-control">
                <label class="ic-Label" for="file-upload-input">File:</label>
                <input type="file" name="file" accept=".csv,text/csv,.ical,.ics,.icalendar,text/calendar"/>
            </div>
            {{#sectionImport}}
                <div class="ic-Form-control">
                    <label class="ic-Label" for="dest-input">Into:</label>
                    <select class="ic-Input" id="dest-input" name="destination" size="1">
                        <option value="">Course: {{course}}</option>
                    </select>
                </div>
            {{/sectionImport}}
            <div class="ic-Form-actions">
                <input class="Button" type="reset" value="Cancel"/>
                <input class="Button Button--primary" type="submit" value="Import"/>
            </div>
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}"/>
        </form>
        <div class="ic-Form-actions debug" style="display: none">
            <form class="ic-Form-group inline-form" id="purge" action="./purge" method="post">
                <input class="Button" type="submit" value="Purge Imported Events"
                       onclick="return confirm('This will remove all events created by this tool in the calendar.');"/>
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}"/>
            </form>
            <form class="ic-Form-group inline-form" id="delete-all" action="./hide" method="post">
                <input class="Button" type="submit" value="Delete All"
                       onclick="return confirm('This will remove all events from this import.');"/>
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}"/>
            </form>
            <form class="ic-Form-group inline-form" id="relogin" action="./relogin" method="post">
                <input class="Button" type="submit" value="Relogin"
                       onclick="return confirm('This will ask you to re-authenticate the application.');"/>
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}"/>
            </form>
        </div>
    </div>

    <div>
        <div class="item-group">
            <div class="ic-Action-header">
                <div class="ic-Action-header__Primary">
                    <h3 class="ic-Action-header__Heading">Previous Imports</h3>
                </div>
                <div class="ic-Action-header__Secondary">
                    <a class="al-trigger btn icon-refresh" href="./" role="button" title="Refresh">Update</a>
                </div>
            </div>
            {{>imports}}


        </div>
        </div>
    </div>
    <footer class="ic-app-footer">
        <div class="text-right row-fluid">
            <div class="version" title="{{version}}">Version: {{version}}</div>
        </div>
    </footer>
</div>
</body>
</html>
